# Backend database
DB_URL=jdbc:h2:file:./data/smart-campus-runtime-db;MODE=MySQL;DB_CLOSE_ON_EXIT=FALSE
DB_USERNAME=sa
DB_PASSWORD=
DB_DRIVER=org.h2.Driver

# Google OAuth for Spring Boot
GOOGLE_OAUTH_ENABLED=true
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret
GOOGLE_OAUTH_AUTHORIZATION_URL=http://localhost:8080/oauth2/authorization/google
GOOGLE_OAUTH_REDIRECT_URI=http://localhost:8080/login/oauth2/code/google
GOOGLE_OAUTH_SUCCESS_URL=http://localhost:5173/?oauth2=success
GOOGLE_OAUTH_FAILURE_URL=http://localhost:5173/?oauth2=error
GOOGLE_DEV_ADMIN_SHORTCUT_ENABLED=false
GOOGLE_DEV_ADMIN_EMAIL=admin@smartcampus.local
GOOGLE_DEV_ADMIN_NAME=Campus Admin

# Optional MySQL production values
# DB_URL=jdbc:mysql://localhost:3306/smart_campus
# DB_USERNAME=root
# DB_PASSWORD=your_mysql_password
# DB_DRIVER=com.mysql.cj.jdbc.Driver
